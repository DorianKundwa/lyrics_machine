# Model cache (large, downloaded at runtime)
# Whisper models (~244MB+) — downloaded to ~/.cache/whisper automatically
# Demucs models — downloaded to ~/.cache/torch/hub automatically
# wav2vec2 models — downloaded to ~/.cache/huggingface automatically

# Large audio files (keep only fixtures)
*.mp3
*.wav
*.flac
*.m4a
*.ogg
*.aac
!tests/fixtures/*.mp3
!tests/fixtures/*.wav

